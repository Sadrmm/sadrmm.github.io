---
import SocialButton from '@/components/SocialButton.astro'

import Copy from '@/assets/svg/copy.svg'
import Spinner from '@/assets/svg/spinner.svg'
import Check from '@/assets/svg/check.svg'
import OpenSVG from '@/assets/svg/open.svg'

interface Props {
    icon: any;
    iconLabel: string;
    value: string;
    href: string;
}

const { icon: Icon, iconLabel, value, href }: Props = Astro.props;
---

<div class="contact-item flex flex-col items-center gap-5 mt-4" data-contact>
    <div class="flex items-center justify-center w-25 h-25 rounded-full bg-skin">
        <Icon class="w-12.5 h-12.5 text-snow"/>
    </div>
    <!-- <span class="text-text-1 text-lg font-bold">{iconLabel}</span> -->

    <div class="flex flex-col md:flex-row gap-5 items-center">
        <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="copy-value text-text-1 text-lg font-bold underline"
            data-value={value}
        >
            {iconLabel}
        </a>
        
        <!-- <div class="flex flex-row gap-2">
            <button
                class="copy-btn flex items-center justify-center w-15 h-7.5 btn-style text-skin"
                aria-label={`Copy ${iconLabel}`}
            >
                <Copy class="copy-icon w-3.75 h-3.75"/>
                <Spinner class="spinner-icon w-3.75 h-3.75 animate-spin hidden"/>
                <Check class="check-icon w-3.75 h-3.75 hidden"/>
                <span class="error-icon text-lg font-bold hidden">X</span>
            </button>
    
            <SocialButton
                href={href}
                icon={OpenSVG}
                anchorSize="w-15 h-7.5"
                anchorRounded="rounded-4xl"
                iconSize="w-3.75 h-3.75"
            />
        </div> -->
    </div>
</div>