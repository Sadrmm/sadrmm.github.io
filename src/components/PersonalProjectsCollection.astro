---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

import { PROJECT_TAGS, COLOR_BY_CATEGORY } from '@/constants/PersonalProjects.ts';

const personalProjects = (await getCollection("personal-projects")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
)
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {personalProjects.map((project) => (
        <a
            href={project.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex basis-1/3 text-text-2 btn-style"
            data-category={project.data.category}
        >
            <div class="flex flex-col border-10 rounded-lg border-bg-3">
                <div class="relative">
                    <Image
                        src={project.data.img}
                        alt={project.data.imgAlt}
                        loading={"lazy"}
                    />
                    <span class="absolute left-3.5 bottom-3.5
                        text-sm font-semibold text-snow rounded-sm px-2.5 py-1 bg-skin"
                    >
                        {project.data.date.getFullYear()}
                    </span>
                </div>
                <div class="m-3.5">
                    <h4 class="text-lg text-text-1 font-bold">
                        {project.data.title}
                    </h4>
                    <div class="flex flex-row flex-wrap gap-2">
                        <span
                            class="text-sm font-normal text-snow rounded-sm px-2 py-1"
                            style={`background-color: ${COLOR_BY_CATEGORY[project.data.category]};`}
                        >
                            {project.data.category}
                        </span>
                        {project.data.tags.map((tag) => (
                            <span
                                class="text-sm font-normal text-snow rounded-sm px-2 py-1"
                                style={`background-color: ${PROJECT_TAGS[tag].color};`}
                            >
                                {PROJECT_TAGS[tag].label}
                            </span>
                        ))}
                    </div>
                </div>
            </div>
        </a>
    ))}
</div>