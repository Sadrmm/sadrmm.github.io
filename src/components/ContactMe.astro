---
import SectionTitle from '@/components/SectionTitle.astro'
import ContactMeItem from '@/components/ContactMeItem.astro'

import Envelope from '@/assets/svg/envelope.svg'
import LinkedIn from '@/assets/svg/linkedin.svg'

interface Props {
	id: string;
}
const { id }: Props = Astro.props;
---

<section id={id} class="flex flex-col bg-bg-1">
    <SectionTitle sectionTitle="Contact Me"/>

    <div class="flex flex-col md:flex-row gap-5 justify-evenly">
        <ContactMeItem
            icon={Envelope}
            iconLabel="adri2001mm@gmail.com"
            value="adri2001mm@gmail.com"
            href="mailto:adri2001mm@gmail.com"
        />

        <ContactMeItem
            icon={LinkedIn}
            iconLabel="LinkedIn"
            value="https://www.linkedin.com/in/adrián-mon-maroto/"
            href="https://www.linkedin.com/in/adrián-mon-maroto/"
        />
    </div>
</section>
